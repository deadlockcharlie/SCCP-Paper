\usepackage[final]{listings}
% Define Language
\lstdefinelanguage{pgkeysLang}
{
  % list of keywords
  morekeywords={
    FOR,
    WITHIN,
    EXCLUSIVE,
    MANDATORY,
    SINGLETON,
    IDENTIFIER,
    OPTIONAL,
    MATCH,
    WHERE,
    NOT,
    OF,
    OR,
    AND,
    EXISTS,
    RETURN,
    IN,
    IS,
    NULL,
    CREATE,
    GRAPH,
    TYPE,
    STRING,
    INT32,
    DATE,
    STRICT,
    hasKey,
    FunctionalProperty,
    context,
    test,
    unique,
    key,
    selector,
    field,
    allInstances,
    isUnique,
    Tuple,
    class,
    extent,
    relationship,
    inverse,
    attribute
  },
  sensitive=false, % keywords are not casesensitive
  morecomment=[l]{//}, % l is for line comment
  morecomment=[s]{/*}{*/}, % s is for start and end delimiter
  morestring=[b]" % defines that strings are enclosed in double quotes
}

