% Define Listings Package
\usepackage{listings}
% Define Language
\lstdefinelanguage{pgkeysLang}
{
  % list of keywords
  morekeywords={
    FOR,
    WITHIN,
    EXCLUSIVE,
    MANDATORY,
    SINGLETON,
    IDENTIFIER,
    MATCH,
    WHERE,
    NOT,
    OR,
    AND,
    EXISTS,
    RETURN,
    OPTIONAL,
    IN,
    IS,
    AS,
    NULL,
    CREATE,
    GRAPH, 
    TYPE,
    STRICT,
    OPEN,
    hasKey,
    FunctionalProperty,
    context,
    test,
    unique,
    key,
    selector,
    field,
    allInstances,
    isUnique,
    Tuple,
    class,
    extent,
    relationship,
    inverse,
    attribute
  },
  sensitive=false, % keywords are not case-sensitive
  morecomment=[l]{//}, % l is for line comment
  morecomment=[s]{/*}{*/}, % s is for start and end delimiter
  morestring=[b]" % defines that strings are enclosed in double quotes
}

